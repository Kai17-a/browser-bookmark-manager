{
  "include": ["."],
  "exclude": ["**/__pycache__", "**/.venv", "**/.pytest_cache", "uv.lock"],
  "typeCheckingMode": "basic",
  "pythonVersion": "3.13",
  "pythonPlatform": "Linux",
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": "error",
  "reportMissingTypeStubs": "warning",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [".."]
    }
  ]
}
